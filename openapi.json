{
  "openapi": "3.1.0",
  "info": {
    "title": "Materio MCP",
    "version": "2.1.2"
  },
  "servers": [
    {
      "url": "https://materiomcp.vercel.app",
      "description": "Production Vercel Host"
    }
  ],
  "paths": {
    "/api/mcp/list_resources": {
      "post": {
        "summary": "List Materio Resources",
        "description": "List all available educational resources in the library. Returns a structured overview of all semesters, subjects, and categories. Optionally pass a 'semester' parameter (1-6) to narrow results.",
        "operationId": "list_resources",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "semester": {
                    "type": "string",
                    "description": "Filter by semester number, e.g. '1', '2', '3'. Omit to list all."
                  }
                },
                "additionalProperties": false
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/mcp/get_resource": {
      "post": {
        "summary": "Search Materio Resources",
        "description": "Search across all Materio PDFs by keyword (like 'deadlocks', 'java'). Searches semesters, subjects, and topics. Takes 'query' (required) and 'limit' (optional). Keep queries broad to find robust results.",
        "operationId": "get_resource",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "query": {
                    "type": "string",
                    "description": "Search keywords to match against subjects, topics, and categories"
                  },
                  "limit": {
                    "type": "number",
                    "description": "Maximum number of results to return (default: 20)"
                  }
                },
                "additionalProperties": false,
                "required": [
                  "query"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/mcp/fetch_pdf": {
      "post": {
        "summary": "Get Materio PDF Content",
        "description": "Fetch and read the full text content of a PDF. Provide EITHER a direct CDN 'url' (from get_resource) OR all three of 'semester, subject, topic'. Do NOT hallucinate parameters. Always cover university-level exam context.",
        "operationId": "fetch_pdf",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string",
                    "description": "Direct CDN URL of the PDF. Takes priority over semester/subject/topic."
                  },
                  "semester": {
                    "type": "string",
                    "description": "Semester number, e.g. '1', '2', '3', '4', '5', '6'."
                  },
                  "subject": {
                    "type": "string",
                    "description": "Subject name exactly as listed in the resource library."
                  },
                  "topic": {
                    "type": "string",
                    "description": "Topic name exactly as listed in the resource library."
                  }
                },
                "additionalProperties": false
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/mcp/share_link": {
      "post": {
        "summary": "Generate Secure Share Link",
        "description": "Get a masked share link to open a PDF in the Materio native viewer beautifully. Takes EITHER a raw CDN 'url' (takes priority) OR 'semester, subject, topic'.",
        "operationId": "share_link",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string",
                    "description": "The raw CDN URL to mask"
                  },
                  "semester": {
                    "type": "string",
                    "description": "Semester number (1-6)"
                  },
                  "subject": {
                    "type": "string",
                    "description": "Subject name exactly as listed"
                  },
                  "topic": {
                    "type": "string",
                    "description": "Topic name exactly as listed"
                  }
                },
                "additionalProperties": false
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/mcp/subject_overview": {
      "post": {
        "summary": "Get Subject Overview",
        "description": "Get a complete overview of all available resources (Chapters, Banks, Assignments) for a specific subject string and semester number. Requires 'semester' and 'subject'.",
        "operationId": "subject_overview",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "semester": {
                    "type": "string",
                    "description": "Semester number, e.g. '1', '2', '3', '4', '5', '6'."
                  },
                  "subject": {
                    "type": "string",
                    "description": "Subject name exactly as listed in the resource library."
                  }
                },
                "additionalProperties": false,
                "required": [
                  "semester",
                  "subject"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    }
  }
}